# Umgebungsvariablen für Appointment Monitor

# URL der zu überwachenden Webseite
TARGET_URL=https://termine.stadt-koeln.de/m/kfz-zulassung/extern/calendar/?uid=67523a04-37af-4131-9495-0a3566e0eb8b&wsid=f40e54e5-3570-4b4f-b999-23f3648c5d9c&lang=de

# Telegram Bot Token (von @BotFather)
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Telegram Chat ID (Eigene Chat ID)
TELEGRAM_CHAT_ID=YOUR_CHAT_ID_HERE

# Prüfintervall im Cron-Format (Standard: alle 10 Minuten)
# Format: "Minute Stunde Tag Monat Wochentag"
# Beispiele:
#   */10 * * * *   = Alle 10 Minuten
#   0 * * * *      = Jede Stunde
#   0 */6 * * *    = Alle 6 Stunden
#   */5 9-17 * * 1-5 = Alle 5 Minuten von 9-17 Uhr, nur Mo-Fr
CHECK_INTERVAL=*/10 * * * *

# Debug-Modus (true/false)
DEBUG=false

# Node Environment
NODE_ENV=production
